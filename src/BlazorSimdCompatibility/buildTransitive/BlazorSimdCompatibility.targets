<Project>

  <!--
    BlazorSimdCompatibility — auto-injected by NuGet package (transitive targets).
    Sets WasmEnableSIMD=false and related compat settings for ReleaseCompat builds.

    NOTE: The .props equivalents are auto-generated by the Razor SDK (static web assets),
    which overwrites custom props at build/, buildMultiTargeting/, and buildTransitive/.
    This .targets file survives because the Razor SDK does not auto-generate .targets files.

    Import order:
      1. SDK .props (early)        - sets defaults
      2. NuGet .props imports       - auto-generated static web assets
      3. Project file
      4. NuGet .targets imports     ← THIS FILE
      5. SDK .targets (late)        - WASM build targets read WasmEnableSIMD here

    WasmEnableSIMD is read by the WASM linker target (step 5), so setting it in
    step 4 works correctly.
  -->

  <PropertyGroup Condition="'$(Configuration)' == 'ReleaseCompat'">
    <!-- Disable SIMD → links libmono-wasm-nosimd.a instead of libmono-wasm-simd.a -->
    <WasmEnableSIMD>false</WasmEnableSIMD>
    <!-- Disable jiterpreter (uses SIMD internally) -->
    <BlazorWebAssemblyJiterpreter>false</BlazorWebAssemblyJiterpreter>
    <!-- Disable WASM exception handling -->
    <WasmEnableExceptionHandling>false</WasmEnableExceptionHandling>
    <!-- Inherit Release optimization -->
    <Optimize>true</Optimize>
    <!-- Explicitly set configuration (in case NuGet props didn't flow it) -->
    <Configuration>ReleaseCompat</Configuration>
  </PropertyGroup>

  <!--
    =========================================================================
    Strip target_features from dotnet.native.wasm (build-time)
    =========================================================================

    PROBLEM: The SDK native strip target (WasmApp.Native.targets) calls
    wasm-opt with +simd +exception-handling, hardcoding the simd feature
    declaration in target_features regardless of WasmEnableSIMD=false.

    On iOS 15 Safari, this declaration causes WebAssembly.validate() to
    reject the module with "SIMD is not supported" before any code runs.

    FIX: Run wasm-opt again to strip the target_features section. The
    browser then validates each instruction directly — since the compat build
    links libmono-wasm-nosimd.a (no actual SIMD instructions), validation
    passes.

    NOTE: This target uses the SDK's internal intermediate path, which may
    differ across SDK versions. A second post-publish target below covers
    cases where this path is unavailable.
  -->
  <Target Name="_BlazorSimdStripFeatureSection"
          AfterTargets="_CompleteWasmBuildNative"
          Condition="'$(Configuration)' == 'ReleaseCompat'">

    <PropertyGroup>
      <_BlazorSimdWasmPath>$(_WasmIntermediateOutputPath)dotnet.native.wasm</_BlazorSimdWasmPath>
    </PropertyGroup>

    <Exec Command="wasm-opt$(_ExeExt) --strip-target-features --enable-mutable-globals --enable-sign-ext --enable-bulk-memory --enable-nontrapping-float-to-int &quot;$(_BlazorSimdWasmPath)&quot; -o &quot;$(_BlazorSimdWasmPath)&quot;"
          Condition="Exists('$(_BlazorSimdWasmPath)')"
          IgnoreStandardErrorWarningFormat="true"
          EnvironmentVariables="@(EmscriptenEnvVars)"
          ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="_BlazorSimdWasmOptExitCode" />
    </Exec>

    <Message Text="BlazorSimdCompatibility: Stripped target_features from dotnet.native.wasm (build-time) ✓"
             Condition="'$(_BlazorSimdWasmOptExitCode)' == '0'"
             Importance="High" />

    <Warning Text="BlazorSimdCompatibility: Build-time wasm-opt skipped (intermediate file not found at $(_BlazorSimdWasmPath)). The post-publish target will handle this."
             Condition="!Exists('$(_BlazorSimdWasmPath)')"
             Importance="High" />
  </Target>

  <!--
    =========================================================================
    Strip target_features from dotnet.native.wasm (post-publish)
    =========================================================================

    This target runs AFTER publish and processes the final published wasm
    file. It is more reliable than the build-time target because:
      - It uses $(PublishDir) which is always available after publish
      - It uses a file pattern (dotnet*.wasm) to handle hashed filenames
      - It does not depend on SDK-specific intermediate paths

    Even if the build-time target already stripped the file, this is
    idempotent (wasm-opt strip-target-features is safe to run multiple
    times).
  -->
  <Target Name="_BlazorSimdStripPublishedWasm"
          AfterTargets="Publish"
          Condition="'$(Configuration)' == 'ReleaseCompat'">

    <ItemGroup>
      <_BlazorSimdPublishedWasmFiles Include="$(PublishDir)wwwroot\_framework\dotnet*.wasm" />
      <_BlazorSimdPublishedWasmFiles Include="$(PublishDir)_framework\dotnet*.wasm" />
    </ItemGroup>

    <Exec Command="wasm-opt$(_ExeExt) --strip-target-features --enable-mutable-globals --enable-sign-ext --enable-bulk-memory --enable-nontrapping-float-to-int &quot;%(_BlazorSimdPublishedWasmFiles.Identity)&quot; -o &quot;%(_BlazorSimdPublishedWasmFiles.Identity)&quot;"
          Condition="'@(_BlazorSimdPublishedWasmFiles)' != ''"
          IgnoreStandardErrorWarningFormat="true"
          EnvironmentVariables="@(EmscriptenEnvVars)"
          ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="_BlazorSimdPublishedWasmOptExitCode" />
    </Exec>

    <Message Text="BlazorSimdCompatibility: Stripped target_features from published dotnet.native.wasm ✓"
             Condition="'$(_BlazorSimdPublishedWasmOptExitCode)' == '0'"
             Importance="High" />

    <Warning Text="BlazorSimdCompatibility: Post-publish wasm-opt failed (code $(_BlazorSimdPublishedWasmOptExitCode)). The compat build may still fail on iOS 15."
             Condition="'$(_BlazorSimdPublishedWasmOptExitCode)' != '0'" />

    <Message Text="BlazorSimdCompatibility: No dotnet*.wasm found in publish output — skipping post-publish strip."
             Condition="'@(_BlazorSimdPublishedWasmFiles)' == ''"
             Importance="High" />
  </Target>

</Project>
